{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "mocha", "@wdio/globals/types"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": ["**/*.ts"],
  "exclude": [
    "node_modules",
    "reports",
    "allure-results",
    "allure-report",
    "test-results"
  ]
}
