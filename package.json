{
  "name": "test-framework-patterns",
  "version": "1.0.0",
  "private": true,
  "description": "Pattern library for modern test automation frameworks and deterministic reference applications.",
  "workspaces": [
    "templates/playwright-template",
    "test-apps/ui-demo-app",
    "test-apps/api-demo-server",
    "tools/create-test-framework-patterns"
  ],
  "scripts": {
    "dev:ui": "npm run dev --workspace @toolstackhq/ui-demo-app",
    "dev:api": "npm run dev --workspace @toolstackhq/api-demo-server",
    "test": "npm run test --workspace @toolstackhq/playwright-template",
    "test:smoke": "npm run test:smoke --workspace @toolstackhq/playwright-template",
    "test:regression": "npm run test:regression --workspace @toolstackhq/playwright-template",
    "lint": "npm run lint --workspace @toolstackhq/playwright-template",
    "typecheck": "npm run typecheck --workspace @toolstackhq/playwright-template",
    "cli": "npm run start --workspace @toolstackhq/create-test-framework-patterns"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
